# Google Gemini API Key
# https://aistudio.google.com/app/apikey からAPIキーを取得してください
GEMINI_API_KEY=your_api_key_here

# Google Sheets / Drive 連携設定
GOOGLE_SHEETS_ID=your_google_sheets_id
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
GOOGLE_EXPERT_SHEET_NAME=カジコン用
GOOGLE_MEMBER_SHEET_NAME=会員用
GEMINI_MODEL=gemini-2.5-flash-lite
HIDE_SETTINGS_PANEL=false

# Streamlit Community Cloud では secrets.toml に以下のように設定可能
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account", ... }'
